{
  "buildCommand": "cd portfolio && npm run build",
  "outputDirectory": "portfolio/dist",
  "installCommand": "cd portfolio && npm install",
  "functions": {
    "api/*.ts": {
      "runtime": "@vercel/node@5"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
